{
  "expo": {
    "name": "Rafa Mobile",
    "slug": "mobile-original",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/rafa_icon.jpeg",
    "scheme": "rafamobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "cli": {
      "appVersionSource": "local"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ios0mobile-rafa",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/rafa_icon.jpeg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gabriel_costa_luiz.mobileoriginal"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "databaseUrl": "mongodb+srv://admin_rafabraga:Zigd0q6eedHw4Qcd@cluster0.8ccvu3w.mongodb.net/?appName=Cluster0",
      "mongodbDb": "rafabraga_db",
      "router": {},
      "eas": {
        "projectId": "3449276c-c949-4d66-a96b-416aab377708"
      }
    }
  }
}
